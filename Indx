margin-bottom: 16px;
}
.section-sub {
text-align: center;
color: var(--text-light);
max-width: 600px;
margin: 0 auto 56px;
font-size: 1.05rem;
}

/* ===== CARDS GRID ===== */
.cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 28px; }

.card {
background: white;
border-radius: var(--radius);
padding: 36px 28px;
box-shadow: var(--shadow);
transition: transform 0.3s, box-shadow 0.3s;
position: relative;
overflow: hidden;
}
.card::before {
content: '';
position: absolute;
top: 0; right: 0;
width: 120px; height: 120px;
border-radius: 0 var(--radius) 0 120px;
opacity: 0.12;
transition: opacity 0.3s;
}
.card:hover { transform: translateY(-6px); box-shadow: var(--shadow-lg); }
.card:hover::before { opacity: 0.25; }

.card-stones::before { background: var(--teal); }
.card-crystals::before { background: var(--amethyst); }
.card-shells::before { background: var(--shell); }

.card-icon {
font-size: 3rem;
margin-bottom: 20px;
display: block;
line-height: 1;
}
.card h3 {
font-family: var(--font-display);
font-size: 1.5rem;
color: var(--deep);
margin-bottom: 12px;
}
.card p { color: var(--text-light); line-height: 1.7; margin-bottom: 16px; }
.card-tag {
display: inline-block;
background: var(--cream);
color: var(--stone);
padding: 4px 14px;
border-radius: 50px;
font-size: 0.8rem;
font-weight: 600;
border: 1px solid var(--sand);
}

/* ===== PROPERTIES SECTION ===== */
.props-section { background: linear-gradient(160deg, #f5eadb, #ede0ce); }

.props-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; }

.prop-item {
background: white;
border-radius: 12px;
padding: 24px 20px;
text-align: center;
box-shadow: 0 4px 20px rgba(74,55,40,0.08);
transition: transform 0.2s;
}
.prop-item:hover { transform: translateY(-4px); }
.prop-icon { font-size: 2.2rem; margin-bottom: 12px; display: block; }
.prop-item h4 { font-family: var(--font-display); font-size: 1.1rem; color: var(--deep); margin-bottom: 8px; }
.prop-item p { font-size: 0.9rem; color: var(--text-light); }

/* ===== CONTACT SECTION ===== */
.contact-section { background: var(--deep); color: white; text-align: center; }
.contact-section .section-title { color: white; }
.contact-section .section-sub { color: rgba(255,255,255,0.7); }

.phones {
display: flex;
justify-content: center;
gap: 24px;
flex-wrap: wrap;
margin-bottom: 36px;
}
.phone-card {
background: rgba(255,255,255,0.1);
border: 1px solid rgba(255,255,255,0.2);
border-radius: var(--radius);
padding: 24px 32px;
min-width: 220px;
}
.phone-card .phone-label { font-size: 0.8rem; opacity: 0.7; margin-bottom: 8px; letter-spacing: 0.08em; }
.phone-card a {
color: white;
font-size: 1.4rem;
font-weight: 700;
text-decoration: none;
display: block;
direction: ltr;
}
.phone-card a:hover { color: var(--teal-light); text-decoration: underline; }

.contact-btns {
display: flex;
gap: 16px;
justify-content: center;
flex-wrap: wrap;
}

/* ===== FOOTER ===== */
footer {
background: #2d1f14;
color: rgba(255,255,255,0.6);
text-align: center;
padding: 24px;
font-size: 0.85rem;
