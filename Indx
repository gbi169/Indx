document.body.appendChild(liveRegion);

function announce(msg) {
document.getElementById('live-region').textContent = '';
setTimeout(() => {
document.getElementById('live-region').textContent = msg;
}, 100);
}

/* Announce when entering major sections */
const observer = new IntersectionObserver((entries) => {
entries.forEach(e => {
if (e.isIntersecting && e.intersectionRatio > 0.5) {
const title = e.target.querySelector('h2');
if (title) announce('נכנסתם לקטע: ' + title.textContent);
}
});
}, { threshold: 0.5 });

document.querySelectorAll('section[aria-labelledby]').forEach(s => observer.observe(s));
</script>

