/* ===== SCREEN READER UTILS ===== */
.sr-only {
position: absolute !important;
width: 1px !important;
height: 1px !important;
overflow: hidden !important;
clip: rect(0,0,0,0) !important;
white-space: nowrap !important;
}

/* ===== READING PROGRESS ===== */
.read-progress {
display: none;
position: fixed;
bottom: 24px;
left: 24px;
background: var(--amethyst);
color: white;
padding: 12px 20px;
border-radius: 50px;
z-index: 999;
font-size: 0.9rem;
font-weight: 600;
box-shadow: var(--shadow);
align-items: center;
gap: 10px;
}
.read-progress.visible { display: flex; }
.stop-btn {
background: rgba(255,255,255,0.25);
border: none;
color: white;
padding: 4px 12px;
border-radius: 20px;
cursor: pointer;
font-size: 0.85rem;
font-family: var(--font-body);
}
.stop-btn:hover { background: rgba(255,255,255,0.4); }

@media (max-width: 600px) {
.nav-links { display: none; }
.a11y-bar { gap: 8px; }
section { padding: 60px 16px; }
}

